{
    "name": "willclaw",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "engines": {
        "node": ">=20"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "esbuild"
        ]
    },
    "scripts": {
        "build": "pnpm --filter @willclaw/core build && pnpm --filter @willclaw/cli build && pnpm --filter @willclaw/web build",
        "lint": "eslint .",
        "format": "prettier --write .",
        "typecheck": "pnpm --filter @willclaw/core typecheck && pnpm --filter @willclaw/cli typecheck && pnpm --filter @willclaw/web typecheck"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.13.10",
        "eslint": "^9.23.0",
        "globals": "^16.0.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.28.0"
    }
}
